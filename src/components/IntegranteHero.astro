---
import Redes from '@/components/CardRedes.astro';

interface Props {
    name: string;
    description: string;
    cover: string;
    youtube?: string;
    instagram?: string;
    x?: string;
    tiktok?: string;
}

const {
    name,
    description,
    cover,
    youtube,
    instagram,
    x,
    tiktok,
} = Astro.props;
---
<section class="perfil-hero">
    <div class="perfil-info">
        <h1>{name}</h1>
        <p>{description}</p>
        {(youtube || instagram || x || tiktok) && (
            <div class="perfil-redes">
                <Redes
                    youtube={youtube}
                    instagram={instagram}
                    x={x}
                    tiktok={tiktok}
                />
            </div>
        )}
    </div>

    <img class="perfil-cover" src={cover} alt={name} />
</section>

<style>
    .perfil-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 1.5rem;
    }

    .perfil-info {
        flex: 1;

        & h1 {
            margin-bottom: 0.5rem;
        }
        & p {
            margin-top: 0;
        }
    }
    .perfil-redes {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;

        @media (width <= 530px) {
            justify-content: center;
        }
    }

    .perfil-cover {
        width: 300px;
        max-width: 40%;
        border-radius: 12px;
    }

    @media (width <= 530px) {
        .perfil-hero {
            flex-direction: column-reverse;
            align-items: flex-start;
        }

        .perfil-cover {
            width: 100%;
            max-width: 100%;
        }
    }
</style>
