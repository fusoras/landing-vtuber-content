---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/integrantes">Integrantes</HeaderLink>
			<HeaderLink href="/about">Sobre nosotros</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.youtube.com/@TonotosCrew" target="_blank">
				<span class="sr-only">Follow Astro on Mastodon</span>
				<svg width="30" height="30">
					<use xlink:href="/sprite.css.svg#youtube" />
				</svg>
			</a>
			<a href="https://x.com/TonotosCrew" target="_blank">
				<span class="sr-only">Follow Astro on Twitter</span>
				<svg width="30" height="30">
					<use xlink:href="/sprite.css.svg#x" />
				</svg>
			</a>
			<a href="https://www.instagram.com/tonotoscrew/" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg width="30" height="30">
					<use xlink:href="/sprite.css.svg#instagram" />
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		border-bottom: 1px solid #000;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
