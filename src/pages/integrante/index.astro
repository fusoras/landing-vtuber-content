---
import { getCollection } from 'astro:content';
import Layout from "@/layouts/Layout.astro"

const integrantes = await getCollection('integrantes')
const hasType = (typeValue: string | string[] | undefined, target: string) => {
    const types = Array.isArray(typeValue)
        ? typeValue
        : typeValue?.split(',').map((type) => type.trim()) ?? []

    return types.includes(target)
}

const fundadores = integrantes.filter(({ data }) => hasType(data.type, 'fundador'))
const staff = integrantes.filter(({ data }) => hasType(data.type, 'staff'))
const renacimiento = integrantes.filter(({ data }) => hasType(data.type, 'renacimiento'))
---

<Layout title="TODOS LOS INTEGRANTES" description="Conoce a los integrantes de Tonotos Crew">
