    <h2>Era de los FUNDADORES</h2>
    <section>
    {
        fundadores.map(integrante => {
            const { id, data } = integrante;
            const { name, description, cover, coverAvif } = data

            return (
                <article>
                    <a href={`/integrante/${id}`}>
                        <picture>
                            {coverAvif && <source srcset={coverAvif} type="image/avif" />}
                            <img src={cover} alt={name} />
                        </picture>
                        <h2>{name}</h2>
                        {/* <p>{description}</p> */}
                    </a>
                </article>
            )
        })
    }
</section>
    <h2>Era renacimiento</h2>
    <section>
    {
        renacimiento.map(integrante => {
            const { id, data } = integrante;
            const { name, description, cover, coverAvif } = data

            return (
                <article>
                    <a href={`/integrante/${id}`}>
                        <picture>
                            {coverAvif && <source srcset={coverAvif} type="image/avif" />}
                            <img transition:name={`img-${id}`} src={cover} alt={name} />
                        </picture>
                        <h2 transition:name={`title-${id}`}>{name}</h2>
                        {/* <p>{description}</p> */}
                    </a>
                </article>
            )
        })
    }
</section>
</section>
    <h2>Staff</h2>
    <section>
    {
        staff.map(integrante => {
            const { id, data } = integrante;
            const { name, description, cover, coverAvif } = data

            return (
                <article>
                    <a href={`/integrante/${id}`}>
                        <picture>
                            {coverAvif && <source srcset={coverAvif} type="image/avif" />}
                            <img transition:name={`img-${id}`} src={cover} alt={name} />
                        </picture>
                        <h2 transition:name={`title-${id}`}>{name}</h2>
                        {/* <p>{description}</p> */}
                    </a>
                </article>
            )
        })
    }
    </section>
</Layout>
<style>
    h1, h2 {
        text-align: center;
        margin: 1em 0;
    }

    section {
        display: flex;
        justify-content: center;
        gap: 1em;
        padding: 1em;
        flex-wrap: wrap;

        & article {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 6px rgb(var(--gray), 25%), 0 8px 24px rgb(var(--gray), 33%),
		0 16px 32px rgb(var(--gray), 33%);
            transition: scale 0.2s ease;
            width: 300px;

            &:hover, &:active {
                scale: 1.02;
            }

            & a {
                display: flex;
                flex-direction: column;
                gap: 1em;
                place-items: center;
                border-radius: inherit;
                padding: 1em;
                padding-block: 1.2em;
                cursor: pointer;
                color: #fff;
                text-decoration: none;

                & h2 {
                    margin: 0;
                }

                & p {
                    text-wrap: balance;
                    margin: 0;
                }

                & img {
                    width: 200px;
                    max-width: 100%;
                    height: auto;
                    border-radius: 50%;
                    aspect-ratio: 1/1;
                }

            }
        }
    }
</style>